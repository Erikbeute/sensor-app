{% extends 'base.html.twig' %}

{% block body %}
<table id="sensorTable" border="1" cellpadding="5">
    <tr>
        <th>Time</th>
        <th>Device</th>
        <th>CO2</th>
        <th>Temp</th>
        <th>Humidity</th>
        <th>pirCount</th>
        <th>Light</th>
        <th>Battery</th>
    </tr>

    {% for row in data %}
        <tr class="sensor-row" data-id="{{ row.id }}" style="cursor: pointer;">
            <td>{{ row.measuredAt|date('H:i:s') }}</td>
            <td>{{ row.deviceName }}</td>
            <td>{{ row.co2 }}</td>
            <td>{{ row.temperature }}</td>
            <td>{{ row.humidity }}</td>
            <td>{{ row.pirCount }}</td>
            <td>{{ row.light}} </td>
            <td>{{ row.battery}} </td>
        </tr>
    {% endfor %}
</table>

<script src="https://unpkg.com/htmx.org"></script>
<script>
    function bindSensorListeners() {
        document.querySelectorAll('.sensor-row').forEach(row => {
            row.addEventListener('click', function() {
                const sensorId = this.dataset.id;
                htmx.ajax('GET', `/sensor-data/${sensorId}`, {
                    target: '#sensorTable',
                    swap: 'innerHTML'
                });
            });
        });
    }

    // Bind listeners initially
    bindSensorListeners();

    // Re-bind after HTMX swaps content
    document.addEventListener('htmx:afterSettle', bindSensorListeners);
</script>
{% endblock %}
