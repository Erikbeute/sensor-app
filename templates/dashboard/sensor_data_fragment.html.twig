<tr>
    <th colspan="8">
        <button onclick="htmx.ajax('GET', '/dashboard/fragment', {target: '#sensorTable', swap: 'innerHTML'})">
            ← Terug naar Dashboard
        </button>
    </th>
</tr>

<tr>
    <th>Time</th>
    <th>Device</th>
    <th>CO2</th>
    <th>Temp</th>
    <th>Humidity</th>
    <th>pirCount</th>
    <th>Light</th>
    <th>Battery</th>
</tr>

{% for row in allData %}
    <tr class="sensor-row" data-id="{{ row.id }}" style="cursor: pointer;">
        <td>{{ row.measuredAt|date('H:i:s') }}</td>
        <td>{{ row.deviceName }}</td>
        <td>{{ row.co2 }}</td>
        <td>{{ row.temperature }}</td>
        <td>{{ row.humidity }}</td>
        <td>{{ row.pirCount }}</td>
        <td>{{ row.light }} </td>
        <td>{{ row.battery }} </td>
    </tr>
{% endfor %}
